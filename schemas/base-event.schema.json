{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.carapacehq.dev/base-event.schema.json",
  "title": "Carapace Base Event",
  "type": "object",
  "required": [
    "type",
    "ts",
    "actor",
    "tags"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "api_request",
        "auth_failure",
        "velocity_burst",
        "prompt_injection_signal",
        "tool_abuse_signal",
        "policy_action"
      ]
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "environment": {
      "type": "string",
      "enum": [
        "production",
        "staging",
        "development",
        "test"
      ]
    },
    "service": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": [
        "ip",
        "userAgent",
        "method",
        "path"
      ],
      "properties": {
        "ip": {
          "type": "string",
          "minLength": 1
        },
        "userAgent": {
          "type": "string",
          "minLength": 1
        },
        "method": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "agentId": {
          "type": "string",
          "minLength": 1
        },
        "organizationId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "request": {
      "type": "object",
      "properties": {
        "method": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "pattern": "^/"
        },
        "userAgent": {
          "type": "string",
          "minLength": 1
        },
        "requestId": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "properties": {
        "statusCode": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        }
      },
      "additionalProperties": false
    },
    "metrics": {
      "type": "object",
      "properties": {
        "hitCount": {
          "type": "integer",
          "minimum": 1
        },
        "windowMs": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "signal": {
      "type": "object",
      "properties": {
        "matchedPattern": {
          "type": "string",
          "minLength": 1
        },
        "toolName": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "policy": {
      "type": "object",
      "required": [
        "action",
        "score",
        "reasons"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "allow",
            "log",
            "rate_limit",
            "block"
          ]
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "additionalProperties": false
}
